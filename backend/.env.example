# PostgreSQL (use same credentials as in pgAdmin4; create DB "inteligent_research" in pgAdmin if needed)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/inteligent_research

# JWT and session (use a long random string in production)
SECRET_KEY=your-secret-key-change-in-production

# JWT algorithm (usually HS256)
ALGORITHM=HS256

# Token expiry in minutes (e.g. 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth: create at https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (for OAuth redirect after login)
FRONTEND_URL=http://localhost:5173

# MongoDB — required for datasheet, research URLs, portfolio, and AI history
# Example: mongodb://localhost:27017
MONGO_URL=
MONGO_DB_NAME=inteligent_research

# Serper.dev Google Search API (https://serper.dev/)
SERPER_API_KEY=

# Groq / Llama 3.3 70B (cleans structured data; free: 1k req/day, 12k TPM; https://console.groq.com/)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Firecrawl web scraping (https://firecrawl.dev/) – 401 = invalid key
FIRECRAWL_API_KEY=
